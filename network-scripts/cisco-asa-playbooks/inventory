# Cisco ASA/Firepower Inventory

[asa_firepower]
# Add your ASA devices here
# asa01 ansible_host=10.1.1.1
# asa02 ansible_host=10.1.1.2

[asa_firepower:vars]
ansible_user=admin
ansible_password=YOUR_PASSWORD_HERE
ansible_connection=network_cli
ansible_network_os=cisco.asa.asa
ansible_become=yes
ansible_become_method=enable
ansible_become_pass=YOUR_ENABLE_PASSWORD
